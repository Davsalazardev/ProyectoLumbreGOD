generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  password      String // bcrypt hash
  name          String
  role          String         @default("ANALYST") // ADMIN, ANALYST, VIEWER
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  projects      Project[]
  comments      Comment[]
  notifications Notification[]

  @@map("users")
}

model Project {
  id                 String               @id @default(cuid())
  name               String
  language           String
  userId             String // Project owner
  path               String? // Local filesystem path for ANALIZADOR projects
  user               User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  analyses           Analysis[]
  branches           Branch[]
  customRules        CustomRule[]
  reports            Report[]
  notifications      Notification[]
  qualityGateHistory QualityGateHistory[]

  @@map("projects")
}

model Analysis {
  id             String           @id @default(cuid())
  projectId      String
  status         String           @default("PENDING") // PENDING | RUNNING | COMPLETED | FAILED
  startedAt      DateTime         @default(now())
  finishedAt     DateTime?
  branchId       String?
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branch         Branch?          @relation(fields: [branchId], references: [id], onDelete: SetNull)
  issues         Issue[]
  metrics        Metric?
  folderMetrics  FolderMetric[]
  fileMetrics    FileMetric[]
  fileComplexity FileComplexity[]
  testResults    TestResult[]

  @@map("analyses")
}

model Issue {
  id                String                 @id @default(cuid())
  analysisId        String
  file              String
  folder            String? // Path to folder (e.g., "src/components")
  line              Int
  column            Int
  severity          String // CRITICAL | MAJOR | MINOR | INFO
  type              String // BUG | VULNERABILITY | CODE_SMELL
  message           String
  rule              String
  codeSnippet       String?                @db.Text
  resolution        String                 @default("OPEN") // OPEN, FALSE_POSITIVE, WONT_FIX, FIXED
  createdDate       DateTime               @default(now()) // When the issue was created
  updatedDate       DateTime?              @updatedAt
  owaspCategory     String? // A1, A2, A3, etc.
  cweId             String? // CWE-79, etc.
  isSecurityHotspot Boolean                @default(false)
  hotspotRiskLevel  String? // LOW, MEDIUM, HIGH
  review            String? // TO_REVIEW, REVIEWED, SAFE, VULNERABLE
  analysis          Analysis               @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  comments          Comment[]
  hotspotDetail     SecurityHotspotDetail?

  @@map("issues")
}

model FolderMetric {
  id              String   @id @default(cuid())
  analysisId      String
  folderPath      String // e.g., "src", "src/components", "src/components/ui"
  bugs            Int      @default(0)
  vulnerabilities Int      @default(0)
  codeSmells      Int      @default(0)
  files           Int      @default(0)
  analysis        Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([analysisId, folderPath])
  @@map("folder_metrics")
}

model FileMetric {
  id              String   @id @default(cuid())
  analysisId      String
  filePath        String // e.g., "src/main.ts"
  bugs            Int      @default(0)
  vulnerabilities Int      @default(0)
  codeSmells      Int      @default(0)
  loc             Int      @default(0) // Lines of code
  analysis        Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([analysisId, filePath])
  @@map("file_metrics")
}

model Metric {
  id                     String             @id @default(cuid())
  analysisId             String             @unique
  bugs                   Int                @default(0)
  vulnerabilities        Int                @default(0)
  codeSmells             Int                @default(0)
  technicalDebt          Int                @default(0) // in minutes
  loc                    Int                @default(0)
  files                  Int                @default(0)
  duplications           Float              @default(0.0) // Duplication %
  coverage               Float              @default(0.0) // Test Coverage %
  cyclomaticComplexity   Float              @default(0.0) // Average complexity
  cognitiveComplexity    Float              @default(0.0) // Cognitive complexity
  maintainabilityIndex   Float              @default(0.0) // 0-100 scale
  maintainabilityRating  String             @default("A") // A-E
  securityRating         String             @default("A") // A-E scale
  reliabilityRating      String             @default("A") // A-E
  sqaleDebt              Int                @default(0) // Technical debt in minutes
  technicalDebtRatio     Float              @default(0.0) // Debt / LOC %
  newIssues              Int                @default(0) // Issues created in this analysis
  resolvedIssues         Int                @default(0) // Issues fixed
  reopenedIssues         Int                @default(0) // Issues reopened
  testCoverage           Float              @default(0.0) // Unit + Integration coverage
  testExecutionTime      Int                @default(0) // Test execution time in ms
  failedTests            Int                @default(0) // Number of failed tests
  owaspA1Issues          Int                @default(0) // OWASP Top 10 issues count
  cweIssuesCount         Int                @default(0) // CWE issues count
  securityHotspots       Int                @default(0) // Security hotspots found
  codeDistributionLow    Int                @default(0) // Lines with low complexity
  codeDistributionMedium Int                @default(0) // Lines with medium complexity
  codeDistributionHigh   Int                @default(0) // Lines with high complexity
  rulesMetadata          String             @default("{}") @db.Text // JSON with rule counts
  analysis               Analysis           @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  metricsHistory         MetricsEvolution[]

  @@map("metrics")
}

model Comment {
  id        String   @id @default(cuid())
  issueId   String
  userId    String
  text      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  projectId String
  type      String // ISSUE_CREATED, QUALITY_GATE_FAILED, REPORT_READY
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Branch {
  id        String     @id @default(cuid())
  projectId String
  name      String
  isMain    Boolean    @default(false)
  createdAt DateTime   @default(now())
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analyses  Analysis[]

  @@map("branches")
}

model CustomRule {
  id        String   @id @default(cuid())
  projectId String
  name      String
  pattern   String   @db.Text
  severity  String   @default("MINOR") // CRITICAL | MAJOR | MINOR | INFO
  type      String   @default("CODE_SMELL") // BUG | VULNERABILITY | CODE_SMELL
  language  String // javascript | python | java
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("custom_rules")
}

model Report {
  id        String   @id @default(cuid())
  projectId String
  type      String // PDF_EXPORT | COMPLIANCE | OWASP | SECURITY_REVIEW
  title     String
  content   String   @db.Text
  format    String   @default("pdf") // pdf | json | html
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("reports")
}

model MetricsEvolution {
  id              String   @id @default(cuid())
  metricId        String
  metric          Metric   @relation(fields: [metricId], references: [id], onDelete: Cascade)
  timestamp       DateTime @default(now())
  bugs            Int
  vulnerabilities Int
  codeSmells      Int
  coverage        Float
  debt            Int
  complexity      Float

  @@map("metrics_evolution")
}

model QualityGateHistory {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status    String // PASSED | FAILED
  reason    String? // Why it failed
  timestamp DateTime @default(now())

  @@map("quality_gate_history")
}

model FileComplexity {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  filePath   String
  complexity Float // Cyclomatic / Cognitive
  loc        Int
  issues     Int
  hotspots   Int
  coverage   Float

  @@map("file_complexity")
}

model SecurityHotspotDetail {
  id                String  @id @default(cuid())
  issueId           String  @unique
  issue             Issue   @relation(fields: [issueId], references: [id], onDelete: Cascade)
  riskLevel         String // LOW, MEDIUM, HIGH
  probability       String // LOW, MEDIUM, HIGH
  impact            String // LOW, MEDIUM, HIGH
  remediation       String  @db.Text
  vulnerabilityType String
  owaspCategory     String?

  @@map("security_hotspot_details")
}

model TestResult {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  testFile   String
  testName   String
  status     String // PASSED, FAILED
  duration   Int // ms
  error      String?  @db.Text

  @@map("test_results")
}
