# CodesCam Backend Configuration

# Server
PORT=4000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://codescam:password@postgres:5432/codescam

# CORS
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@codescam.dev
NOTIFY_CRITICAL_EMAIL=true

# GitHub Integration
GITHUB_TOKEN=ghp_your-github-token

# Repository Paths
TEMP_REPO_PATH=/tmp/codescam-repos

# Analysis Configuration
MAX_FILE_SIZE_MB=50
ANALYSIS_TIMEOUT_MS=60000
